# ---------- Core ----------
APP_ENV=development
APP_NAME=MailGuard AI Ultra
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# ---------- Security ----------
JWT_SECRET=change-me-in-production-please
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
AES_SECRET=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=

# ---------- Database ----------
DATABASE_URL=postgresql+psycopg2://mailguard:mailguard@postgres:5432/mailguard
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---------- AI ----------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TTS_MODEL=tts-1
GOOGLE_TTS_KEY=optional-google-cloud-tts-key

# ---------- Gmail OAuth ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/accounts/gmail/callback
GMAIL_PUBSUB_TOPIC=projects/your-project/topics/mailguard-gmail

# ---------- Outlook OAuth ----------
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT=common
MS_REDIRECT_URI=http://localhost:8000/api/v1/accounts/outlook/callback

# ---------- WhatsApp ----------
WHATSAPP_PROVIDER=meta    # meta | twilio
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155550123

# ---------- Vector DB ----------
CHROMA_PERSIST_DIR=/data/chroma
EMBEDDING_DIM=1536

# ---------- Telemetry ----------
SENTRY_DSN=
LOG_LEVEL=INFO
